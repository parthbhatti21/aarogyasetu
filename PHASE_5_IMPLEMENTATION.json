{
  "name": "Phase 5: Notifications System",
  "description": "Multi-channel notification system with Email, SMS, and WhatsApp support",
  "version": "1.0.0",
  "status": "✅ Implemented",
  "components": {
    "frontend": [
      {
        "name": "NotificationsPanel",
        "path": "src/components/patient/NotificationsPanel.tsx",
        "description": "Main notification UI with real-time updates",
        "features": [
          "Real-time notification display",
          "Mark as read functionality",
          "Notification type badges",
          "Delivery channel indicators",
          "Auto-refresh on new notifications"
        ]
      },
      {
        "name": "useNotifications hook",
        "path": "src/hooks/useNotifications.ts",
        "description": "React hook for notification management",
        "features": [
          "Fetch notifications",
          "Real-time subscriptions",
          "Mark as read",
          "Unread count",
          "Error handling"
        ]
      }
    ],
    "backend": [
      {
        "name": "notificationService",
        "path": "src/services/notificationService.ts",
        "description": "Service layer for notification operations",
        "methods": [
          "createNotification()",
          "sendNotification()",
          "sendAppointmentReminder()",
          "sendTokenUpdate()",
          "sendPrescriptionReady()",
          "sendLabReportReady()",
          "markAsRead()",
          "getUnreadCount()"
        ]
      },
      {
        "name": "notificationIntegrations",
        "path": "src/services/notificationIntegrations.ts",
        "description": "Example integrations with existing features",
        "examples": [
          "createTokenWithNotification()",
          "updateTokenStatusWithNotification()",
          "sendAppointmentReminders()",
          "notifyPrescriptionReady()",
          "notifyLabReportReady()"
        ]
      }
    ],
    "edge_functions": [
      {
        "name": "email-notification",
        "path": "supabase/functions/email-notification/",
        "description": "Supabase Edge Function for sending emails via Gmail SMTP",
        "features": [
          "Gmail SMTP integration",
          "HTML email templates",
          "Email validation",
          "Error handling",
          "Delivery logging"
        ]
      }
    ],
    "database": [
      {
        "name": "notifications table",
        "description": "Stores all patient notifications",
        "columns": [
          "id (UUID)",
          "patient_id (FK)",
          "type (enum)",
          "title (text)",
          "message (text)",
          "send_email (boolean)",
          "send_sms (boolean)",
          "send_whatsapp (boolean)",
          "send_push (boolean)",
          "status (enum: Pending, Sent, Failed, Read)",
          "sent_at (timestamp)",
          "read_at (timestamp)",
          "related_entity_type (text)",
          "related_entity_id (text)",
          "created_at (timestamp)"
        ]
      },
      {
        "name": "email_logs table",
        "description": "Tracks email delivery for debugging",
        "columns": [
          "id (UUID)",
          "recipient (text)",
          "subject (text)",
          "body (text)",
          "status (text)",
          "external_id (text)",
          "sent_at (timestamp)",
          "created_at (timestamp)"
        ]
      }
    ]
  },
  "notification_types": [
    {
      "type": "Token Update",
      "description": "Queue token status changes",
      "channels": ["push", "email (optional)"],
      "example": "Your token A-042 is now active"
    },
    {
      "type": "Appointment Reminder",
      "description": "Upcoming appointment reminders",
      "channels": ["email", "sms", "push"],
      "example": "Appointment tomorrow at 10:00 AM in Cardiology"
    },
    {
      "type": "Prescription Ready",
      "description": "Prescription available for pickup",
      "channels": ["email", "sms"],
      "example": "Your prescription is ready at the pharmacy"
    },
    {
      "type": "Lab Report Ready",
      "description": "Lab test results available",
      "channels": ["email", "push"],
      "example": "Your lab results are now available"
    },
    {
      "type": "General",
      "description": "General system notifications",
      "channels": ["email", "push"],
      "example": "Welcome to Aarogya Setu!"
    }
  ],
  "delivery_channels": {
    "email": {
      "status": "✅ Implemented",
      "provider": "Gmail SMTP",
      "features": [
        "HTML templates",
        "Personalization",
        "Delivery tracking"
      ]
    },
    "sms": {
      "status": "🚧 Planned",
      "provider": "Twilio / AWS SNS",
      "notes": "Scaffold ready in notificationService.ts"
    },
    "whatsapp": {
      "status": "🚧 Planned",
      "provider": "Twilio / WhatsApp Business API",
      "notes": "Scaffold ready in notificationService.ts"
    },
    "push": {
      "status": "🚧 Planned",
      "provider": "Firebase Cloud Messaging",
      "notes": "In-app notifications implemented"
    }
  },
  "setup": {
